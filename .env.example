# ===== Обязательное =====
# Токен от @BotFather
BOT_TOKEN=123456:ABC-your-token-here

# Твой Telegram ID (узнать: @userinfobot). Нужен для /admin
ADMIN_ID=0

# ===== Режим =====
# true  -> оплата эмулируется (для теста)
# false -> подключаешь реальную оплату
TEST_MODE=true

# ===== Оплата (СБП / карты) =====
# Токен провайдера из @BotFather: бот -> Payments -> Connect ЮKassa.
# Пусто -> бот работает на тестовой заглушке (без реальной оплаты).
# Для теста можно взять "Connect ЮKassa Test" и тестовую карту.
PROVIDER_TOKEN=
CURRENCY=RUB

# false -> long polling (домен НЕ нужен, для теста — оставь так)
# true  -> webhook (нужен свой домен + SSL)
USE_WEBHOOK=false

# ===== Только для webhook (когда USE_WEBHOOK=true) =====
WEBHOOK_HOST=https://your-domain.com
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=придумай-длинную-строку
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
